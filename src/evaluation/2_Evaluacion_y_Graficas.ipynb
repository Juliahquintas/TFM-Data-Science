                "## 2. Generar Matrices de Confusión"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {
                "id": "code-3"
            },
            "outputs": [],
            "source": [
                "def plot_confusion_mat(y_real, y_prediccion):\n",
                "    cm = confusion_matrix(y_real, y_prediccion)\n",
                "    plt.figure(figsize=(6, 5))\n",
                "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n",
                "                xticklabels=['Sano (HC)', 'Parkinson (PD)'],\n",
                "                yticklabels=['Sano (HC)', 'Parkinson (PD)'])\n",
                "    plt.title('Matriz de Confusión del Modelo')\n",
                "    plt.ylabel('Etiqueta Real')\n",
                "    plt.xlabel('Predicción del Modelo')\n",
                "    plt.show()\n",
                "\n",
                "# Las generarías así:\n",
                "# plot_confusion_mat([0,1,1,0], [0,1,0,0])"
            ]
        }
